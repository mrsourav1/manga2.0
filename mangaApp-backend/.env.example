PORT=5001
NODE_ENV=production
REDIS_URL=redis://redis:6379

# Comma-separated list for production web clients, or * to allow all origins.
CORS_ORIGIN=*
TRUST_PROXY=false

ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120

ENABLE_PREFETCH_WORKER=true
HOMEPAGE_PREFETCH_PAGES=3
PREFETCH_INTERVAL_MS=86400000

HOME_CACHE_TTL_SECONDS=86400
DETAILS_CACHE_TTL_SECONDS=86400
CHAPTER_CACHE_TTL_SECONDS=86400
SEARCH_CACHE_TTL_SECONDS=86400

REQUEST_TIMEOUT_MS=30000
SEARCH_SOURCE_TIMEOUT_MS=8000

ASURA_BASE_URL=https://asurascans.com
MANHUAPLUS_BASE_URL=https://manhuaplus.com
MANHUAUS_BASE_URL=https://manhuaus.com
MANGABUDDY_BASE_URL=https://mangabuddy.com
